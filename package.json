{
  "name": "gaslights",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npx --yes serve public",
    "test": "node --test tests/*.test.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "validate:maps": "node scripts/validate-map-sources.mjs",
    "test:all": "npm run validate:data && npm run validate:maps && npm test",
    "nls:batch:prep": "node scripts/batch-prepare-nls-sheets.mjs",
    "nls:batch:board": "python3 scripts/render-crop-review-board.py",
    "nls:crop:export": "node scripts/export-crop-review-table.mjs",
    "nls:crop:apply": "node scripts/apply-crop-overrides.mjs",
    "nls:crop:review": "node scripts/crop-review-server.mjs",
    "nls:build:reviewed": "node scripts/build-reviewed-historical-layer.mjs",
    "nls:manifest:mapfinder": "node scripts/build-manifest-from-mapfinder.mjs"
  },
  "devDependencies": {
    "serve": "^14.2.4"
  }
}
