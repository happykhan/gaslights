{
  "name": "gaslights",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npx --yes serve public",
    "authoring:dev": "node scripts/dev-authoring.mjs",
    "test": "node --test tests/*.test.mjs",
    "editor": "node scripts/location-editor-server.mjs",
    "editor:locations": "node scripts/location-editor-server.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "validate:maps": "node scripts/validate-map-sources.mjs",
    "publish:check": "npm run validate:data && npm run validate:maps && npm test",
    "publish:checklist": "node scripts/publish-checklist.mjs",
    "publish:prep": "npm run publish:check && npm run publish:checklist",
    "test:all": "npm run validate:data && npm run validate:maps && npm test",
    "nls:batch:prep": "node scripts/batch-prepare-nls-sheets.mjs",
    "nls:batch:board": "python3 scripts/render-crop-review-board.py",
    "nls:crop:export": "node scripts/export-crop-review-table.mjs",
    "nls:crop:apply": "node scripts/apply-crop-overrides.mjs",
    "nls:crop:review": "node scripts/crop-review-server.mjs",
    "nls:build:reviewed": "node scripts/build-reviewed-historical-layer.mjs",
    "nls:build:preview": "node scripts/build-reviewed-historical-layer.mjs --mode preview",
    "nls:build:draft": "node scripts/build-reviewed-historical-layer.mjs --mode draft",
    "nls:build:full": "node scripts/build-reviewed-historical-layer.mjs --mode full",
    "nls:manifest:mapfinder": "node scripts/build-manifest-from-mapfinder.mjs",
    "pois:review": "node scripts/poi-review-server.mjs",
    "pois:osm:import": "node scripts/import-osm-pois.mjs",
    "pois:gb1900:filter": "python3 scripts/filter-gb1900-pois.py",
    "pois:gb1900:osm": "python3 scripts/enrich-gb1900-pois-osm.py",
    "pois:gb1900:queue": "python3 scripts/build-poi-review-queue.py"
  },
  "devDependencies": {
    "serve": "^14.2.4"
  }
}
